{
  "expo": {
    "name": "КарьерГид",
    "slug": "careerguid",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a1a"
    },
    "android": {
      "package": "com.careerguid.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6366f1"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.careerguid.app",
      "supportsTablet": false,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "КарьерГид использует геолокацию, чтобы подсказывать курсы и места рядом с тобой."
      }
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "КарьерГид использует геолокацию, чтобы подсказывать курсы и места рядом с тобой."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "7d47608a-7669-46f0-9b20-e994f9cef15a"
      }
    },
    "owner": "yelnurchik"
  }
}
